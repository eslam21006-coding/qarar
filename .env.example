# Database
DATABASE_URL=

# Better Auth (Phase A — placeholders only, no real secrets)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://app.adqarar.com

# GHL webhook (Phase C) — placeholders only, no real secrets
# GHL_WEBHOOK_SECRET: signing key GHL uses for the x-ghl-signature header.
#                       Leave empty in local dev to skip signature verification.
# GHL_ACTIVE_TAG: tag name that toggles a user to `active` (defaults to "qarar-active").
GHL_WEBHOOK_SECRET=
GHL_ACTIVE_TAG=qarar-active
# GHL_PROVISION_SECRET: shared secret for POST /api/webhooks/ghl/provision
#                       (GHL workflow integration). Sent as the
#                       x-ghl-provision-secret header (or ?token=). MUST be
#                       >= 32 bytes or the route fails closed (rejects all).
#                       Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GHL_PROVISION_SECRET=

# Admin auto-elevation
ADMIN_EMAIL=

# Public app URL (client-side)
VITE_APP_URL=https://app.adqarar.com
